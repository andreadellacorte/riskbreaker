# Copy this file to .env and fill in your local paths.
# .env is gitignored; .env.example is the tracked template.
#
# Playwright loads .env automatically — no extra setup needed.
# Vite also picks up these vars for the dev-server preload feature.

# ── E2E tests ─────────────────────────────────────────────────────────────────

# Path to the Vagrant Story NTSC-U disc image (.bin file from a .bin/.cue pair).
# Required for all emulator e2e tests (vagrant-story-*.spec.ts, psx-ram-api.spec.ts).
# Relative paths are resolved from the repo root.
E2E_PS1_DISC_BIN=bins/roms/Vagrant Story (USA)/Vagrant Story (USA).bin

# Override the save-state fixture used by VS e2e tests (optional).
# Defaults to the last alphabetical vs-save-*.state in
#   plugins/vagrant-story/e2e/fixtures/
# VS_SAVE_STATE=plugins/vagrant-story/e2e/fixtures/vs-save-2026-03-24T13-36-04.state


# ── Dev-server preloader (Vite only) ─────────────────────────────────────────
#
# Open the emulator with ?preload=1 and the dev server will automatically:
#   1. Load PRELOAD_PS1_DISC_BIN into the emulator (no file picker needed).
#   2. Load PRELOAD_PS1_SAVE_STATE once the game is active (optional).
#
# Example: http://127.0.0.1:5173/pcsx-wasm/index.html?riskbreaker=1&preload=1
#
# Paths are resolved from the repo root.
PRELOAD_PS1_DISC_BIN=bins/roms/Vagrant Story (USA)/Vagrant Story (USA).bin

# Optional: save state to restore after disc load.
# PRELOAD_PS1_SAVE_STATE=plugins/vagrant-story/e2e/fixtures/vs-save-2026-03-24T13-36-04.state
