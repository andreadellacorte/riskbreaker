{
  "name": "riskbreaker",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @riskbreaker/web dev",
    "dev:docs": "pnpm --filter @riskbreaker/docs dev",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:pcsx-wasm-shell": "node packages/pcsx-wasm-shell/build.mjs",
    "ensure:pcsx-wasm": "node scripts/ensure-pcsx-wasm.mjs",
    "sync:pcsx-wasm": "node scripts/sync-pcsx-wasm-public.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p apps/docs/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "verify:playstation-riskbreaker-controls": "node scripts/verify-playstation-riskbreaker-controls.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@riskbreaker/app-shell": "workspace:*",
    "@riskbreaker/plugin-vagrant-story": "workspace:*",
    "@types/node": "^24.0.0",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.0.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "husky": "^9.1.7",
    "vitest": "^4.1.0"
  }
}
